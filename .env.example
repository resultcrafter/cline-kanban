# Cline Kanban environment configuration
# Copy this file to .env and fill in values

# === Required ===

# Anthropic API key (or compatible proxy)
ANTHROPIC_API_KEY=
# API base URL (change if using a proxy)
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Model to use
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Project paths inside the container (comma-separated)
# If unset, all git repos under /projects/*/ are auto-discovered
KANBAN_PROJECTS=/projects/geo-audit-adk

# === Optional ===

# ZAI API key — enables ZAI MCP servers (web search, code reader, etc.)
# Z_AI_API_KEY=

# Disable automatic container updates
KANBAN_NO_AUTO_UPDATE=1

# Basic auth for the web UI
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASS=

# === Usually not needed (entrypoint handles git safe.directory automatically) ===
# GIT_CONFIG_COUNT=1
# GIT_CONFIG_KEY_0=safe.directory
# GIT_CONFIG_VALUE_0=*
